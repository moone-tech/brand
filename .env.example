# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=moone_brand
DB_USER=postgres
DB_PASSWORD=

# Auth
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Brevo (email)
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@mo.one
BREVO_FROM_NAME=Mo.one Brand

# App
APP_URL=http://localhost:5173

{
  "buildCommand": "npm install && npm run build --workspace=client",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://brand-production-c033.up.railway.app/api/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
